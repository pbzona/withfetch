{
  "name": "@pbzona/withfetch",
  "version": "0.0.7",
  "description": "Composable fetch instances with preset headers",
  "type": "module",
  "publishConfig": {
    "access": "public",
    "@pbzona:registry": "https://registry.npmjs.org"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "rolldown -c && tsc --emitDeclarationOnly",
    "dev": "rolldown -c --watch",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "pnpm run build"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "@types/node": "^25.5.2",
    "rolldown": "^1.0.0-rc.13",
    "typescript": "^5.8.0",
    "vitest": "^3.0.0"
  },
  "keywords": [
    "fetch",
    "headers",
    "middleware",
    "oidc",
    "vercel",
    "bearer",
    "auth"
  ],
  "author": "",
  "license": "MIT",
  "packageManager": "pnpm@10.28.2"
}
